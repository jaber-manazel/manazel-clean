}

function openReceiptModal(receiptId = null) {
  currentEditingReceiptId = receiptId;
  updateContractDropdowns();
  
  if(receiptId) {
    document.getElementById('receipt-title').innerText = "تعديل سند القبض";
    const r = receipts.find(rec => rec.id === receiptId);
    document.getElementById('r-amount').value = r.amount;
    document.getElementById('r-name').value = r.name;
    document.getElementById('r-contract-id').value = r.contractId || "";
    document.getElementById('r-notes').value = r.notes || "";
    document.getElementById('r-date').value = r.date;
    document.getElementById('btn-print-receipt').style.display = "inline-block";
  } else {
    document.getElementById('receipt-title').innerText = "إنشاء سند قبض مالي (وارد للمنشأة)";
    document.getElementById('r-amount').value = "";
    document.getElementById('r-name').value = "";
    document.getElementById('r-contract-id').value = "";
    document.getElementById('r-notes').value = "";
    document.getElementById('r-date').value = new Date().toISOString().split('T')[0];
    document.getElementById('btn-print-receipt').style.display = "none";
  }
  document.getElementById('receipt-modal').style.display = "flex";
}

