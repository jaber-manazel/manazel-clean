<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>منازل الكرام - فندق أبراج نوازي</title>
<style>
:root{
  --main:#0f766e;--main2:#064e3b;--dark:#0f172a;--red:#991b1b;--gold:#c89b3c;--bg:#f5f7fb;--line:#d7dee9;
  --green:#16a34a;--danger:#dc2626;--blue:#2563eb;--amber:#f59e0b;--purple:#7c3aed;--muted:#64748b;
}
*{box-sizing:border-box;font-family:Tahoma,Arial,sans-serif}
body{margin:0;background:linear-gradient(180deg,#f8fafc,#edf2f7);color:#111827}
header{background:linear-gradient(135deg,#064e3b,#0f172a);color:white;padding:18px 20px;display:flex;align-items:center;gap:16px;justify-content:center;text-align:center}
.logo{width:78px;height:78px;border-radius:18px;background:white;object-fit:contain;padding:6px;box-shadow:0 8px 18px rgba(0,0,0,.18)}
header h1{margin:0;font-size:28px} header p{margin:6px 0 0;color:#fde68a;font-weight:bold}
nav{display:flex;gap:8px;flex-wrap:wrap;padding:12px;background:#fff;border-bottom:1px solid var(--line);position:sticky;top:0;z-index:10;box-shadow:0 4px 12px rgba(15,23,42,.06)}
button{border:0;border-radius:10px;padding:9px 12px;cursor:pointer;font-weight:bold}
nav button{background:#edf7f5;color:#064e3b;border:1px solid #cde5df}
nav button.active{background:var(--main);color:white}
main{max-width:1400px;margin:auto;padding:16px}
.screen{display:none}.screen.active{display:block}
.card{background:white;border:1px solid var(--line);border-radius:18px;padding:16px;margin-bottom:15px;box-shadow:0 8px 24px rgba(15,23,42,.08)}
.card-title{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px}
label{font-size:13px;font-weight:bold;color:#334155}
input,select,textarea{width:100%;padding:10px;border:1px solid var(--line);border-radius:10px;margin-top:5px;background:white}
textarea{min-height:75px}
.primary{background:var(--blue);color:white}.success{background:var(--green);color:white}.danger{background:var(--danger);color:white}
.warning{background:var(--amber);color:white}.purple{background:var(--purple);color:white}.muted{background:#e2e8f0;color:#0f172a}.mainbtn{background:var(--main);color:white}
.kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:12px;margin-bottom:15px}
.kpi{border-radius:18px;padding:17px;color:white;font-weight:bold;box-shadow:0 8px 18px rgba(15,23,42,.12)}
.kpi b{display:block;font-size:29px;margin-top:8px}.kpi small{display:block;opacity:.9;margin-top:5px}
.kpi.green{background:var(--green)}.kpi.red{background:var(--danger)}.kpi.amber{background:var(--amber)}.kpi.blue{background:var(--blue)}.kpi.purple{background:var(--purple)}.kpi.dark{background:var(--dark)}.kpi.main{background:var(--main)}
.toolbar{display:flex;gap:8px;flex-wrap:wrap;align-items:end;margin:10px 0}
.toolbar>*{min-width:165px}
.legend{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0}
.legend span{padding:6px 10px;border-radius:999px;color:white;font-size:12px;font-weight:bold}
.floor-head{background:#f8fafc;border:1px solid var(--line);padding:10px 12px;border-radius:12px;margin:14px 0 8px;display:flex;justify-content:space-between;align-items:center}
.room-map{display:grid;grid-template-columns:repeat(auto-fill,minmax(92px,1fr));gap:9px}
.room{min-height:84px;border-radius:15px;color:#fff;padding:8px;text-align:center;display:flex;flex-direction:column;justify-content:center;gap:4px;box-shadow:0 6px 14px rgba(15,23,42,.16);cursor:pointer;transition:.15s}
.room:hover{transform:translateY(-2px);filter:brightness(1.04)}
.room .num{font-size:19px;font-weight:bold}.room .status{font-size:12px}.room .guest{font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;opacity:.95}
.available{background:var(--green)}.occupied{background:var(--danger)}.cleaning{background:var(--amber)}.maintenance{background:var(--blue)}.reserved{background:var(--purple)}
table{width:100%;border-collapse:collapse;background:white;border-radius:14px;overflow:hidden}
th,td{border:1px solid var(--line);padding:8px;text-align:center;font-size:13px}
th{background:linear-gradient(135deg,#064e3b,#0f172a);color:white}
tr:nth-child(even) td{background:#f8fafc}
.actions{display:flex;gap:5px;justify-content:center;flex-wrap:wrap}
.actions button{padding:7px 9px;font-size:12px}
.badge{display:inline-block;padding:5px 9px;border-radius:999px;color:white;font-weight:bold;font-size:12px}
.modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:100;align-items:center;justify-content:center;padding:15px}
.modal-box{background:white;border-radius:18px;padding:18px;width:100%;max-width:720px;max-height:92vh;overflow:auto}
.modal-head{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--line);padding-bottom:10px;margin-bottom:12px}
.close{background:#e2e8f0;color:#0f172a}
.form-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
.print-logo{width:80px;height:80px;object-fit:contain}
.print-title{text-align:center;margin-bottom:14px;display:none}
.voucher-box{border:2px solid var(--main);border-radius:16px;padding:22px;background:#fff;line-height:1.9}
.voucher-box h2,.voucher-box h3{text-align:center;margin:5px 0}
.company-line{font-size:13px;color:#475569}
@media(max-width:650px){
  header{flex-direction:column} header h1{font-size:22px}
  nav{overflow:auto;flex-wrap:nowrap} nav button{white-space:nowrap}
  .room-map{grid-template-columns:repeat(auto-fill,minmax(75px,1fr))}
  .room{min-height:74px}
}
@media print{
  body{background:white} header,nav,.no-print,.modal{display:none!important}
  main{max-width:none;padding:0} .screen{display:none!important} .screen.active{display:block!important}
  .card{box-shadow:none;border:0} .print-title{display:block} button{display:none!important}
  th{background:#064e3b!important;color:white!important;-webkit-print-color-adjust:exact;print-color-adjust:exact}
}
</style>
</head>
<body>

<header>
  <img class="logo" src="data:image/jpeg;base64,_9" />
  <div>
    <h1>منازل الكرام</h1>
    <p>فندق أبراج نوازي</p>
  </div>
</header>

<nav class="no-print">
  <button class="active" onclick="showScreen('dashboard')">الرئيسية</button>
  <button onclick="showScreen('rooms-screen')">مخطط الغرف</button>
  <button onclick="showScreen('contracts-screen')">الحجوزات والعقود</button>
  <button onclick="showScreen('cashbox-screen')">الصندوق المالي</button>
  <button onclick="showScreen('settings-screen')">الإعدادات</button>
</nav>

<main>
  <div id="dashboard" class="screen active">
    <div class="kpis">
      <div class="kpi main">الإجمالي العام للغرف<b id="kpi-total">0</b></div>
      <div class="kpi green">الغرف الشاغرة<b id="kpi-avail">0</b></div>
      <div class="kpi red">الغرف المسكونة<b id="kpi-occ">0</b></div>
      <div class="kpi purple">المحجوزة مؤكداً<b id="kpi-res">0</b></div>
      <div class="kpi amber">تحت التنظيف<b id="kpi-clean">0</b></div>
      <div class="kpi blue">تحت الصيانة<b id="kpi-maint">0</b></div>
      <div class="kpi dark">الرصيد المالي بالحساب<b id="kpi-cash">0.00</b></div>
    </div>
    <div class="card">
      <h3>مخطط نسب الإشغال السريع</h3>
      <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
        <div>
          <label>نسبة الإشغال الفعلية (المسكونة)</label>
          <div style="background:#e2e8f0; border-radius:10px; height:24px; margin-top:5px; overflow:hidden; position:relative;">
            <div id="bar-occ" style="background:var(--danger); height:100%; width:0%; transition:0.3s;"></div>
            <span id="txt-occ" style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-weight:bold; color:#000; font-size:12px;">0%</span>
          </div>
        </div>
        <div>
          <label>نسبة الغرف المتاحة للبيع فوراً</label>
          <div style="background:#e2e8f0; border-radius:10px; height:24px; margin-top:5px; overflow:hidden; position:relative;">
            <div id="bar-avail" style="background:var(--green); height:100%; width:0%; transition:0.3s;"></div>
            <span id="txt-avail" style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-weight:bold; color:#000; font-size:12px;">0%</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="rooms-screen" class="screen">
    <div class="card">
      <div class="card-title">
        <h2>لوحة التحكم الرقمية ومخطط الفندق (بدون أرقام غرف)</h2>
        <div class="legend no-print">
          <span class="available">متاحة</span>
          <span class="occupied">مسكونة</span>
          <span class="reserved">محجوزة</span>
          <span class="cleaning">تنظيف</span>
          <span class="maintenance">صيانة</span>
        </div>
      </div>
      <div class="toolbar no-print">
        <div>
          <label>تصفية بحالة الغرفة:</label>
          <select id="filter-status" onchange="renderRoomMap()">
            <option value="all">كل الحالات</option>
            <option value="متاحة">متاحة</option>
            <option value="مسكونة">مسكونة</option>
            <option value="محجوزة">محجوزة مؤكداً</option>
            <option value="تنظيف">تحت التنظيف</option>
            <option value="صيانة">تحت الصيانة</option>
          </select>
        </div>
        <div>
          <label>البحث باسم النزيل:</label>
          <input type="text" id="search-guest" placeholder="اكتب اسم النزيل..." oninput="renderRoomMap()">
        </div>
      </div>
      <div id="floors-container"></div>
    </div>
  </div>

  <div id="contracts-screen" class="screen">
    <div class="card">
      <div class="card-title">
        <h2>إدارة عقود التسكين والحجوزات</h2>
        <button class="mainbtn no-print" onclick="openContractModal()">+ إضافة حجز / عقد جديد</button>
      </div>
      <div class="toolbar no-print">
        <div>
          <label>البحث الشامل:</label>
          <input type="text" id="contract-search" placeholder="اسم، شركة، هاتف..." oninput="renderContracts()">
        </div>
      </div>
      <div style="overflow-x:auto; margin-top:15px;">
        <table id="contracts-table">
          <thead>
            <tr>
              <th>رقم العقد</th>
              <th>النزيل / الجهة</th>
              <th>الشركة / البعثة</th>
              <th>تاريخ الدخول</th>
              <th>تاريخ الخروج</th>
              <th>عدد الغرف</th>
              <th>الحالة</th>
              <th>المالية (مطلوب/مدفوع)</th>
              <th class="no-print">إجراءات</th>
            </tr>
          </thead>
          <tbody id="contracts-rows"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="cashbox-screen" class="screen">
    <div class="card">
      <div class="card-title">
        <h2>حركة الصندوق المالي والوصولات</h2>
        <div class="actions no-print">
          <button class="success" onclick="openReceiptModal()">+ سند قبض (وارد)</button>
          <button class="danger" onclick="openPaymentModal()">+ سند صرف (صادر)</button>
        </div>
      </div>
      <div class="kpis" style="margin-top:15px;">
        <div class="kpi green">إجمالي المقبوضات<b id="cash-in-total">0.00</b></div>
        <div class="kpi red">إجمالي المصروفات<b id="cash-out-total">0.00</b></div>
        <div class="kpi dark">الرصيد الفعلي الحالي<b id="cash-balance">0.00</b></div>
      </div>
      <div style="overflow-x:auto;">
        <table>
          <thead>
            <tr>
              <th>التاريخ</th>
              <th>النوع</th>
              <th>رقم السند</th>
              <th>الإسم / البيان</th>
              <th>المبلغ القبض (+)</th>
              <th>المبلغ الصرف (-)</th>
              <th>الرصيد التراكمي</th>
              <th>ملاحظات</th>
              <th class="no-print">إجراءات</th>
            </tr>
          </thead>
          <tbody id="cashbox-rows"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="settings-screen" class="screen">
    <div class="card">
      <h2>إعدادات النظام وهيكلة الغرف بالفندق</h2>
      <p style="color:var(--muted); font-size:13px;">تتيح لك هذه الشاشة تهيئة الفندق بالكامل، وتحديد عدد الغرف في كل طابق بشكل مرن دون الارتباط بأرقام تسلسلية ثابتة.</p>
      
      <div class="grid" style="grid-template-columns:1fr 1fr; gap:15px;">
        <div>
          <label>اسم الفندق / المنشأة بالكامل:</label>
          <input type="text" id="set-hotel-name" value="فندق أبراج نوازي">
        </div>
        <div>
          <label>السطر الفرعي في الهيدر:</label>
          <input type="text" id="set-hotel-sub" value="مجموعة منازل الكرام لخدمات الحجاج والمعتمرين">
        </div>
      </div>

      <div style="margin-top:20px; border-top:1px solid var(--line); padding-top:15px;">
        <h3>تخصيص الطوابق وعدد الغرف</h3>
        <div class="grid" style="grid-template-columns:1fr 1fr 100px; align-items:end; gap:10px;">
          <div>
            <label>اسم الطابق (مثال: الطابق الأول، المتكرر، ميزانين):</label>
            <input type="text" id="new-floor-name" placeholder="مثال: الطابق الأول">
          </div>
          <div>
            <label>عدد الغرف المراد إنشاؤها في هذا الطابق:</label>
            <input type="number" id="new-floor-count" placeholder="مثال: 25">
          </div>
          <button class="mainbtn" style="width:100%;" onclick="addNewFloorConfiguration()">+ إضافة</button>
        </div>

        <div style="overflow-x:auto; margin-top:15px;">
          <table style="min-width:500px;">
            <thead>
              <tr>
                <th>اسم الطابق التوضيحي</th>
                <th>إجمالي الغرف المتاحة فيه</th>
                <th>إجراءات</th>
              </tr>
            </thead>
            <tbody id="settings-floors-rows"></tbody>
          </table>
        </div>
      </div>

      <div style="margin-top:20px; padding-top:15px; border-top:1px solid var(--line);" class="actions">
        <button class="success" onclick="saveGeneralSettings()">حفظ كافة التعديلات والإعدادات</button>
        <button class="warning" onclick="exportBackupData()">تصدير نسخة احتياطية (JSON)</button>
        <button class="purple" onclick="document.getElementById('import-file').click()">استيراد نسخة احتياطية</button>
        <input type="file" id="import-file" style="display:none;" onchange="importBackupData(event)">
        <button class="danger" onclick="resetSystemData()">صفر النظام بالكامل (مسح دائم)</button>
      </div>
    </div>
  </div>
</main>

<div id="contract-modal" class="modal">
  <div class="modal-box">
    <div class="modal-head">
      <h3 id="contract-modal-title">إنشاء عقد تسكين جديد</h3>
      <button class="close" onclick="closeModal('contract-modal')">X</button>
    </div>
    <div class="grid">
      <div>
        <label>اسم النزيل / الجهة المستأجرة *</label>
        <input type="text" id="c-name" required>
      </div>
      <div>
        <label>الشركة / البعثة / الحملة</label>
        <input type="text" id="c-company">
      </div>
      <div>
        <label>رقم الهاتف / التواصل</label>
        <input type="text" id="c-phone">
      </div>
      <div>
        <label>رقم الهوية / جواز السفر</label>
        <input type="text" id="c-nid">
      </div>
      <div>
        <label>تاريخ وقت الدخول (Check-In) *</label>
        <input type="date" id="c-date-in" required>
      </div>
      <div>
        <label>تاريخ وقت الخروج (Check-Out) *</label>
        <input type="date" id="c-date-out" required>
      </div>
      <div>
        <label>إجمالي قيمة العقد المالية (ريال)</label>
        <input type="number" id="c-total-amount" value="0" oninput="calculateContractRemaining()">
      </div>
      <div>
        <label>المبلغ المدفوع كدفعة أولى (ريال)</label>
        <input type="number" id="c-paid-amount" value="0" oninput="calculateContractRemaining()">
      </div>
      <div>
        <label>المبلغ المتبقي تلقائياً (ريال)</label>
        <input type="number" id="c-remain-amount" value="0" readonly style="background:#f1f5f9;">
      </div>
      <div>
        <label>حالة العقد</label>
        <select id="c-status">
          <option value="مؤكد فعلي">مؤكد فعلي (نشط)</option>
          <option value="حجز مؤقت">حجز مؤقت (غير مسكون)</option>
          <option value="منتهي">منتهي ومغلق</option>
          <option value="ملغي">ملغي</option>
        </select>
      </div>
    </div>
    <div style="margin-top:12px;">
      <label>طريقة اختيار وتعيين الغرف (يمكنك حجز الغرف مباشرة بالضغط عليها من لوحة مخطط الغرف):</label>
      <div id="contract-rooms-selected-badge-area" style="margin-top:6px; min-height:30px; padding:8px; border:1px dashed var(--line); border-radius:10px;">
        لا توجد غرف مخصصة لهذا العقد حالياً.
      </div>
    </div>
    <div>
      <label>ملاحظات إضافية وشروط التسكين</label>
      <textarea id="c-notes"></textarea>
    </div>
    <div class="form-actions">
      <button class="success" id="btn-save-contract" onclick="saveContractSubmit()">حفظ وتثبيت العقد</button>
      <button class="muted" onclick="closeModal('contract-modal')">إلغاء</button>
    </div>
  </div>
</div>

<div id="room-detail-modal" class="modal">
  <div class="modal-box" style="max-width:550px;">
    <div class="modal-head">
      <h3>إدارة وتحديث حالة الغرفة البرمجية</h3>
      <button class="close" onclick="closeModal('room-detail-modal')">X</button>
    </div>
    <p style="font-weight:bold; color:var(--main);" id="rd-title">غرفة رقم X - الطابق Y</p>
    
    <div style="margin-bottom:12px;">
      <label>تغيير حالة الغرفة التشغيلية الحالية:</label>
      <select id="rd-status" onchange="toggleRoomDetailStatusLogic()">
        <option value="متاحة">متاحة - جاهزة للبيع</option>
        <option value="مسكونة">مسكونة - نزيل فعلي</option>
        <option value="محجوزة">محجوزة مؤكداً</option>
        <option value="تنظيف">تحت التنظيف / التدبير المنزلي</option>
        <option value="صيانة">تحت الصيانة الفنية</option>
      </select>
    </div>

    <div id="rd-contract-area" style="display:none; border:1px solid var(--line); padding:12px; border-radius:12px; margin-bottom:12px; background:#f8fafc;">
      <label>ربط هذه الغرفة بعقد تسكين قائم للنزلاء:</label>
      <select id="rd-contract-id">
        <option value="">-- اختر العقد لربط الغرفة وتسكينها --</option>
      </select>
      <p style="font-size:11px; color:var(--muted); margin:4px 0 0;">عند ربط الغرفة بعقد، سيظهر اسم النزيل تلقائياً على الغرفة في المخطط العام للفندق.</p>
    </div>

    <div>
      <label>ملاحظات خاصة بالغرفة (مثال: بحاجة لتغيير لمبة، عطل بالتكييف)</label>
      <textarea id="rd-notes"></textarea>
    </div>

    <div class="form-actions" style="margin-top:15px;">
      <button class="success" onclick="saveRoomDetailSubmit()">حفظ التغييرات التشغيلية</button>
      <button class="danger" onclick="removeRoomFromSystemConfiguration()">حذف هذه الغرفة نهائياً من الطابق</button>
      <button class="muted" onclick="closeModal('room-detail-modal')">إغلاق</button>
    </div>
  </div>
</div>

<div id="receipt-modal" class="modal">
  <div class="modal-box" style="max-width:500px;">
    <div class="modal-head">
      <h3 id="receipt-title">إنشاء سند قبض مالي (وارد للمنشأة)</h3>
      <button class="close" onclick="closeModal('receipt-modal')">X</button>
    </div>
    <div style="display:grid; gap:10px;">
      <div>
        <label>المبلغ المستلم (ريال سعودي) *</label>
        <input type="number" id="r-amount" required>
      </div>
      <div>
