<script>
// الكيانات البرمجية وقاعدة البيانات المحلية الافتراضية
let systemSettings = {
  hotelName: "فندق أبراج نوازي",
  hotelSub: "مجموعة منازل الكرام لخدمات الحجاج والمعتمرين"
};

let floors = [];
let rooms = {};
let contracts = [];
let receipts = [];
let payments = [];

let currentEditingContractId = null;
let currentEditingRoomGlobalId = null;
let currentEditingReceiptId = null;
let currentEditingPaymentId = null;

// التحميل والتشغيل الأولي عند فتح المتصفح
window.onload = function() {
  loadAllDataFromLocalStorage();
  applySettingsUI();
  renderAll();
};

function showScreen(screenId) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  
  const targetScreen = document.getElementById(screenId);
  if(targetScreen) targetScreen.classList.add('active');
  
  // تفعيل زر النقل المناسب
  const btn = Array.from(document.querySelectorAll('nav button')).find(b => b.getAttribute('onclick').includes(screenId));
  if(btn) btn.classList.add('active');
}

function loadAllDataFromLocalStorage() {
  if(localStorage.getItem('nawazi_settings')) {
    systemSettings = JSON.parse(localStorage.getItem('nawazi_settings'));
  }
  if(localStorage.getItem('nawazi_floors')) {
    floors = JSON.parse(localStorage.getItem('nawazi_floors'));
  } else {
    // بناء فندق افتراضي تجريبي عند أول تشغيل للنظام
    floors = [
      { id: "f1", name: "الطابق الأول (أ)", count: 12 },
      { id: "f2", name: "الطابق الثاني (ب)", count: 15 },
      { id: "f3", name: "الطابق الثالث (ج)", count: 10 }
    ];
  }
  
  if(localStorage.getItem('nawazi_rooms')) {
    rooms = JSON.parse(localStorage.getItem('nawazi_rooms'));
  } else {
    // توليد الغرف الافتراضية برمجياً بناء على الطوابق المحددة
    generateRoomsFromScratchConfig();
  }
  
  if(localStorage.getItem('nawazi_contracts')) {
    contracts = JSON.parse(localStorage.getItem('nawazi_contracts'));
  }
  if(localStorage.getItem('nawazi_receipts')) {
    receipts = JSON.parse(localStorage.getItem('nawazi_receipts'));
  }
  if(localStorage.getItem('nawazi_payments')) {
    payments = JSON.parse(localStorage.getItem('nawazi_payments'));
  }
}

function saveAll() {
  localStorage.setItem('nawazi_settings', JSON.stringify(systemSettings));
  localStorage.setItem('nawazi_floors', JSON.stringify(floors));
  localStorage.setItem('nawazi_rooms', JSON.stringify(rooms));
  localStorage.setItem('nawazi_contracts', JSON.stringify(contracts));
  localStorage.setItem('nawazi_receipts', JSON.stringify(receipts));
  localStorage.setItem('nawazi_payments', JSON.stringify(payments));
}

function generateRoomsFromScratchConfig() {
  rooms = {};
  floors.forEach(f => {
    for(let i = 1; i <= f.count; i++) {
      const roomId = `${f.id}_r${i}`;
      rooms[roomId] = {
        id: roomId,
        floorId: f.id,
        localIndex: i, 
        status: "متاحة",
        contractId: "",
        notes: ""
      };
    }
  });
}

function applySettingsUI() {
  document.querySelector('header h1').innerText = systemSettings.hotelName;
  document.querySelector('header p').innerText = systemSettings.hotelSub;
  document.getElementById('set-hotel-name').value = systemSettings.hotelName;
  document.getElementById('set-hotel-sub').value = systemSettings.hotelSub;
}

function renderAll() {
  calculateKPIsAndDash();
  renderRoomMap();
  renderContracts();
  renderCashbox();
  renderSettingsFloorsTable();
  updateContractDropdowns();
}

function calculateKPIsAndDash() {
  let total = Object.keys(rooms).length;
  let avail = 0, occ = 0, res = 0, clean = 0, maint = 0;
  
  Object.values(rooms).forEach(r => {
    if(r.status === "متاحة") avail++;
    else if(r.status === "مسكونة") occ++;
    else if(r.status === "محجوزة") res++;
    else if(r.status === "تنظيف") clean++;
    else if(r.status === "صيانة") maint++;
  });
  
  document.getElementById('kpi-total').innerText = total;
  document.getElementById('kpi-avail').innerText = avail;
  document.getElementById('kpi-occ').innerText = occ;
  document.getElementById('kpi-res').innerText = res;
  document.getElementById('kpi-clean').innerText = clean;
  document.getElementById('kpi-maint').innerText = maint;
  
  // الحساب المالي المجمع للصندوق
  let totalIn = receipts.reduce((sum, r) => sum + Number(r.amount || 0), 0);
  let totalOut = payments.reduce((sum, p) => sum + Number(p.amount || 0), 0);
  let balance = totalIn - totalOut;
  document.getElementById('kpi-cash').innerText = balance.toFixed(2) + " ريال";
  
  // نسب شريط التقدم بالداشبورد
  let pctOcc = total > 0 ? ((occ / total) * 100).toFixed(1) : 0;
  let pctAvail = total > 0 ? ((avail / total) * 100).toFixed(1) : 0;
  
  document.getElementById('bar-occ').style.width = pctOcc + "%";
  document.getElementById('txt-occ').innerText = pctOcc + "%";
  document.getElementById('bar-avail').style.width = pctAvail + "%";
  document.getElementById('txt-avail').innerText = pctAvail + "%";
}

function renderRoomMap() {
  const container = document.getElementById('floors-container');
  container.innerHTML = "";
  
  const filterStatus = document.getElementById('filter-status').value;
  const searchGuest = document.getElementById('search-guest').value.trim().toLowerCase();
  
  floors.forEach(f => {
    const floorRooms = Object.values(rooms).filter(r => r.floorId === f.id);
    
    // تصفية الغرف برمجياً حسب مدخلات المستخدم بالبحث
    let filteredRooms = floorRooms.filter(r => {
      let matchesStatus = (filterStatus === "all" || r.status === filterStatus);
      let matchesGuest = true;
      
      if(searchGuest) {
        matchesGuest = false;
        if(r.contractId) {
          const c = contracts.find(con => con.id === r.contractId);
          if(c && (c.name.toLowerCase().includes(searchGuest) || (c.company && c.company.toLowerCase().includes(searchGuest)))) {
            matchesGuest = true;
          }
        }
      }
      return matchesStatus && matchesGuest;
    });
    
    if(floorRooms.length === 0) return; // طابق فارغ لا يعرض
    
    const floorHead = document.createElement('div');
    floorHead.className = "floor-head";
    floorHead.innerHTML = `<h3>${f.name}</h3><small>يعرض ${filteredRooms.length} غرف من أصل ${floorRooms.length}</small>`;
    container.appendChild(floorHead);
    
    const roomMap = document.createElement('div');
    roomMap.className = "room-map";
    
    filteredRooms.forEach(r => {
      let statusClass = "available";
      if(r.status === "مسكونة") statusClass = "occupied";
      else if(r.status === "محجوزة") statusClass = "reserved";
      else if(r.status === "تنظيف") statusClass = "cleaning";
      else if(r.status === "صيانة") statusClass = "maintenance";
      
      let guestName = "-";
      if(r.contractId) {
        const c = contracts.find(con => con.id === r.contractId);
        if(c) guestName = c.name;
      }
      
      const div = document.createElement('div');
      div.className = `room ${statusClass}`;
      div.setAttribute('onclick', `openRoomDetailModal('${r.id}')`);
      div.innerHTML = `<span class="num">غ ${r.localIndex}</span>
                       <span class="status">${r.status}</span>
                       <span class="guest" title="${guestName}">${guestName}</span>`;
      roomMap.appendChild(div);
    });
    
    container.appendChild(roomMap);
  });
}

function openRoomDetailModal(roomId) {
  currentEditingRoomGlobalId = roomId;
  const r = rooms[roomId];
  if(!r) return;
  
  const f = floors.find(fl => fl.id === r.floorId);
  document.getElementById('rd-title').innerText = `غرفة رقم المتسلسل (${r.localIndex}) - بالطابق: ${f ? f.name : ''}`;
  document.getElementById('rd-status').value = r.status;
  document.getElementById('rd-notes').value = r.notes || "";
  
  toggleRoomDetailStatusLogic();
  document.getElementById('rd-contract-id').value = r.contractId || "";
  
  document.getElementById('room-detail-modal').style.display = "flex";
}

function toggleRoomDetailStatusLogic() {
  const status = document.getElementById('rd-status').value;
  const area = document.getElementById('rd-contract-area');
  if(status === "مسكونة" || status === "محجوزة") {
    area.style.display = "block";
  } else {
    area.style.display = "none";
  }
}

function saveRoomDetailSubmit() {
  if(!currentEditingRoomGlobalId) return;
  const r = rooms[currentEditingRoomGlobalId];
  
  const oldStatus = r.status;
  const newStatus = document.getElementById('rd-status').value;
  const newContractId = document.getElementById('rd-contract-id').value;
  
  r.status = newStatus;
  r.notes = document.getElementById('rd-notes').value;
  
  if(newStatus === "مسكونة" || newStatus === "محجوزة") {
    r.contractId = newContractId;
  } else {
    r.contractId = ""; // تفريغ الغرفة من النزيل تلقائياً في حال إتاحتها أو تنظيفها
  }
  
  saveAll();
  renderAll();
  closeModal('room-detail-modal');
}

function removeRoomFromSystemConfiguration() {
  if(!currentEditingRoomGlobalId) return;
  if(confirm('هل أنت متأكد تماماً من رغبتك في حذف هذه الغرفة من النظام البرمجي نهائياً؟')) {
    delete rooms[currentEditingRoomGlobalId];
    saveAll();
    renderAll();
    closeModal('room-detail-modal');
  }
}

function renderContracts() {
  const rows = document.getElementById('contracts-rows');
  rows.innerHTML = "";
  const query = document.getElementById('contract-search').value.trim().toLowerCase();
  
  let filtered = contracts.filter(c => {
    return c.id.toLowerCase().includes(query) || 
           c.name.toLowerCase().includes(query) || 
           (c.company && c.company.toLowerCase().includes(query)) ||
           (c.phone && c.phone.includes(query));
  });
  
  filtered.forEach(c => {
    // حساب الغرف التابعة للعقد حالياً
    const contractRoomsCount = Object.values(rooms).filter(r => r.contractId === c.id).length;
    
    let badgeClass = "success";
    if(c.status === "حجز مؤقت") badgeClass = "warning";
    if(c.status === "منتهي") badgeClass = "muted";
    if(c.status === "ملغي") badgeClass = "danger";
    
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><b>${c.id}</b></td>
      <td>${c.name} <br><small style="color:var(--muted)">ت:${c.phone||'-'}</small></td>
      <td>${c.company || '-'}</td>
      <td>${c.dateIn}</td>
      <td>${c.dateOut}</td>
      <td><span class="badge primary">${contractRoomsCount} غرف</span></td>
      <td><span class="badge ${badgeClass}">${c.status}</span></td>
      <td>
        <small>المطلوب: ${Number(c.totalAmount).toFixed(2)}</small><br>
        <small style="color:var(--green)">المدفوع: ${Number(c.paidAmount).toFixed(2)}</small><br>
        <small style="color:var(--red)">المتبقي: ${Number(c.remainAmount).toFixed(2)}</small>
      </td>
      <td class="no-print">
        <div class="actions">
          <button class="primary" onclick="openContractModal('${c.id}')">تعديل</button>
          <button class="warning" onclick="quickAssignRoomsToContract('${c.id}')">تعيين غرف</button>
          <button class="danger" onclick="deleteContract('${c.id}')">حذف</button>
        </div>
      </td>
    `;
    rows.appendChild(tr);
  });
}

function openContractModal(contractId = null) {
  currentEditingContractId = contractId;
  
  if(contractId) {
    // حالة التعديل على عقد موجود
    document.getElementById('contract-modal-title').innerText = "تعديل بيانات عقد التسكين والمالية";
    const c = contracts.find(con => con.id === contractId);
    
    document.getElementById('c-name').value = c.name;
    document.getElementById('c-company').value = c.company || "";
    document.getElementById('c-phone').value = c.phone || "";
    document.getElementById('c-nid').value = c.nid || "";
    document.getElementById('c-date-in').value = c.dateIn;
    document.getElementById('c-date-out').value = c.dateOut;
    document.getElementById('c-total-amount').value = c.totalAmount;
    document.getElementById('c-paid-amount').value = c.paidAmount;
    document.getElementById('c-remain-amount').value = c.remainAmount;
    document.getElementById('c-status').value = c.status;
    document.getElementById('c-notes').value = c.notes || "";
    
    renderSelectedRoomsBadges(c.id);
  } else {
    // حجز جديد
    document.getElementById('contract-modal-title').innerText = "إنشاء عقد تسكين جديد";
    document.getElementById('c-name').value = "";
    document.getElementById('c-company').value = "";
    document.getElementById('c-phone').value = "";
    document.getElementById('c-nid').value = "";
    
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('c-date-in').value = today;
    document.getElementById('c-date-out').value = today;
    
    document.getElementById('c-total-amount').value = 0;
    document.getElementById('c-paid-amount').value = 0;
    document.getElementById('c-remain-amount').value = 0;
    document.getElementById('c-status').value = "مؤكد فعلي";
    document.getElementById('c-notes').value = "";
    
    document.getElementById('contract-rooms-selected-badge-area').innerHTML = "سيتم تخصيص الغرف بعد حفظ العقد عبر لوحة التحكم السريعة.";
  }
  
  document.getElementById('contract-modal').style.display = "flex";
}

function calculateContractRemaining() {
  const total = Number(document.getElementById('c-total-amount').value || 0);
  const paid = Number(document.getElementById('c-paid-amount').value || 0);
  document.getElementById('c-remain-amount').value = (total - paid).toFixed(2);
}

function renderSelectedRoomsBadges(contractId) {
  const area = document.getElementById('contract-rooms-selected-badge-area');
  area.innerHTML = "";
  
  const connectedRooms = Object.values(rooms).filter(r => r.contractId === contractId);
  if(connectedRooms.length === 0) {
    area.innerHTML = "لا توجد غرف مخصصة لهذا العقد حالياً. اذهب لمخطط الغرف واضغط على أي غرفة لربطها.";
    return;
  }
  
  connectedRooms.forEach(r => {
    const span = document.createElement('span');
    span.className = "badge primary";
    span.style.margin = "3px";
    span.innerText = `غرفة ${r.localIndex}`;
    area.appendChild(span);
  });
}

function saveContractSubmit() {
  const name = document.getElementById('c-name').value.trim();
  if(!name) { alert('الرجاء إدخال اسم النزيل أو الجهة المستأجرة رئيسياً'); return; }
  
  const dateIn = document.getElementById('c-date-in').value;
  const dateOut = document.getElementById('c-date-out').value;
  const totalAmount = Number(document.getElementById('c-total-amount').value || 0);
  const paidAmount = Number(document.getElementById('c-paid-amount').value || 0);
  const remainAmount = totalAmount - paidAmount;
  const status = document.getElementById('c-status').value;
  
  if(currentEditingContractId) {
    // تحديث العقد المالي والبيانات
    const c = contracts.find(con => con.id === currentEditingContractId);
    c.name = name;
    c.company = document.getElementById('c-company').value.trim();
    c.phone = document.getElementById('c-phone').value.trim();
    c.nid = document.getElementById('c-nid').value.trim();
    c.dateIn = dateIn;
    c.dateOut = dateOut;
    c.totalAmount = totalAmount;
    c.paidAmount = paidAmount;
    c.remainAmount = remainAmount;
    c.status = status;
    c.notes = document.getElementById('c-notes').value;
  } else {
    // إضافة حجز جديد لقاعدة البيانات
    const newId = "CNT-" + Math.floor(1000 + Math.random() * 9000);
    contracts.push({
      id: newId,
      name,
      company: document.getElementById('c-company').value.trim(),
      phone = document.getElementById('c-phone').value.trim(),
      nid: document.getElementById('c-nid').value.trim(),
      dateIn, dateOut, totalAmount, paidAmount, remainAmount, status,
      notes: document.getElementById('c-notes').value
    });
  }
  
  saveAll();
  renderAll();
  closeModal('contract-modal');
}

function quickAssignRoomsToContract(contractId) {
  alert(`قم بالتوجه الآن إلى صفحة 'مخطط الغرف'، واضغط على الغرف المراد حجزها ثم اختر هذا العقد [${contractId}] لربطه بها تلقائياً.`);
  showScreen('rooms-screen');
}

function deleteContract(id) {
  if(confirm('هل تريد حذف هذا العقد نهائياً؟ سيتم إلغاء ربط الغرف التابعة له تلقائياً.')) {
    // تحرير غرف الفندق المرتبطة بالعقد الملغي
    Object.values(rooms).forEach(r => {
      if(r.contractId === id) {
        r.contractId = "";
        r.status = "متاحة";
      }
    });
    contracts = contracts.filter(c => c.id !== id);
    saveAll();
    renderAll();
  }
}

function renderCashbox() {
  const cashboxRows = document.getElementById('cashbox-rows');
  cashboxRows.innerHTML = "";
  
  let allLogs = [];
  receipts.forEach(r => {
    allLogs.push({ date: r.date, type: 'قبض', id: r.id, name: r.name, credit: r.amount, debit: 0, notes: r.notes });
  });
  payments.forEach(p => {
    allLogs.push({ date: p.date, type: 'صرف', id: p.id, name: p.name, credit: 0, debit: p.amount, notes: p.notes });
  });
  
  // ترتيب السجلات المالية تصاعدياً حسب التاريخ والسند لضبط الرصيد التراكمي
  allLogs.sort((a,b) => new Date(a.date) - new Date(b.date));
  
  let balance = 0;
  let totalIn = 0;
  let totalOut = 0;
  
  allLogs.forEach(e => {
    balance += Number(e.credit||0) - Number(e.debit||0);
    totalIn += Number(e.credit||0);
    totalOut += Number(e.debit||0);
    
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${e.date || '-'}</td>
      <td><span class="badge ${e.type==='قبض'?'success':'danger'}">${e.type}</span></td>
      <td><b>${e.id}</b></td>
      <td>${e.name}</td>
      <td style="color:var(--green); font-weight:bold;">${e.credit > 0 ? Number(e.credit).toFixed(2) : '-'}</td>
      <td style="color:var(--red); font-weight:bold;">${e.debit > 0 ? Number(e.debit).toFixed(2) : '-'}</td>
      <td style="font-weight:bold;">${balance.toFixed(2)}</td>
      <td>${e.notes || '-'}</td>
      <td class="no-print">
        <div class="actions">
          ${e.type === 'قبض' ? 
            `<button class="primary" onclick="openReceiptModal('${e.id}')">تعديل</button><button class="danger" onclick="deleteReceipt('${e.id}')">حذف</button>` : 
            `<button class="primary" onclick="openPaymentModal('${e.id}')">تعديل</button><button class="danger" onclick="deletePayment('${e.id}')">حذف</button>`
          }
        </div>
      </td>
    `;
    cashboxRows.appendChild(tr);
  });
  
  document.getElementById('cash-in-total').innerText = totalIn.toFixed(2) + " ريال";
  document.getElementById('cash-out-total').innerText = totalOut.toFixed(2) + " ريال";
